[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "asd"]
	path = asd
	url = https://github.com/cran/asd
[submodule "gsearly"]
	path = gsearly
	url = https://github.com/cran/gsearly
[submodule "repolr"]
	path = repolr
	url = https://github.com/cran/repolr
